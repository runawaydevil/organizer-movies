# ===========================================
# CRITICAL: API Keys and Sensitive Data
# ===========================================
# NEVER commit these files - they contain real API keys!
config.json
api_keys.json
tmdb_config.json
openai_config.json
user_config.json
*.config.json
*_config.json

# Secure Configuration Directories (Local storage only)
# Windows: %LOCALAPPDATA%/MovieOrganizer/
# Linux: ~/.config/movie-organizer/
**/MovieOrganizer/
**/.config/movie-organizer/
**/AppData/Local/MovieOrganizer/

